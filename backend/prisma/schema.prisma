// Prisma Schema for Jass Tournament Manager
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

enum UserRole {
  SYSADMIN
  ORGANIZER
  PLAYER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  organizedTournaments Tournament[]
  configTemplates      TournamentConfigTemplate[]
  participations       TournamentParticipant[]
  enteredScores        GameScore[]
  enteredPairings      GameParticipant[]
  tables               Table[]

  @@index([email])
}

// ============================================
// TOURNAMENT
// ============================================

enum TournamentStatus {
  OPEN
  COMPLETED
  CANCELLED
}

model Tournament {
  id          String           @id @default(uuid())
  organizerId String
  name        String
  location    String?
  date        DateTime         @db.Date
  status      TournamentStatus @default(OPEN)
  qrCode      String?          @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  organizer    User                    @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  config       TournamentConfig?
  participants TournamentParticipant[]
  rounds       Round[]

  @@index([organizerId])
  @@index([status])
  @@index([date])
}

// ============================================
// CONFIGURATION
// ============================================

enum ScoreVisibility {
  ALWAYS_VISIBLE
  HIDDEN_DURING_TOURNAMENT
  ORGANIZER_ONLY
}

model TournamentConfigTemplate {
  id                 String          @id @default(uuid())
  organizerId        String
  name               String
  numberOfRounds     Int             @default(5)
  gamesPerRound      Int             @default(8)
  matchBonusEnabled  Boolean         @default(true)
  fixedTeams         Boolean         @default(false)
  scoreVisibility    ScoreVisibility @default(ALWAYS_VISIBLE)
  isDefault          Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Relations
  organizer User               @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  configs   TournamentConfig[]

  @@unique([organizerId, name])
  @@index([organizerId])
  @@index([organizerId, isDefault])
}

model TournamentConfig {
  id                String          @id @default(uuid())
  tournamentId      String          @unique
  templateId        String?
  numberOfRounds    Int             @default(5)
  gamesPerRound     Int             @default(8)
  matchBonusEnabled Boolean         @default(true)
  fixedTeams        Boolean         @default(false)
  scoreVisibility   ScoreVisibility @default(ALWAYS_VISIBLE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relations
  tournament Tournament                @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  template   TournamentConfigTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
}

// ============================================
// PARTICIPANTS
// ============================================

enum RegistrationMethod {
  MANUAL
  QR_CODE
  EXCEL_IMPORT
}

model TournamentParticipant {
  id                 String             @id @default(uuid())
  tournamentId       String
  userId             String
  registrationMethod RegistrationMethod
  registeredAt       DateTime           @default(now())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  tournament       Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameParticipants GameParticipant[]

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

// ============================================
// ROUNDS & GAMES
// ============================================

enum RoundStatus {
  OPEN
  COMPLETED
}

model Round {
  id           String      @id @default(uuid())
  tournamentId String
  roundNumber  Int
  status       RoundStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  // Relations
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  games      Game[]

  @@unique([tournamentId, roundNumber])
  @@index([tournamentId])
  @@index([status])
}

// ============================================
// TABLES
// ============================================

model Table {
  id           String   @id @default(uuid())
  organizerId  String
  name         String
  displayOrder Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  organizer User   @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  games     Game[]

  @@unique([organizerId, name])
  @@index([organizerId])
  @@index([organizerId, isActive])
}

// ============================================
// GAMES
// ============================================

enum GameStatus {
  OPEN
  COMPLETED
}

model Game {
  id          String     @id @default(uuid())
  roundId     String
  gameNumber  Int
  tableId     String?
  status      GameStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  round        Round             @relation(fields: [roundId], references: [id], onDelete: Cascade)
  table        Table?            @relation(fields: [tableId], references: [id], onDelete: SetNull)
  participants GameParticipant[]
  score        GameScore?

  @@unique([roundId, gameNumber])
  @@index([roundId])
  @@index([status])
}

// ============================================
// GAME PARTICIPANTS & SCORES
// ============================================

enum Team {
  TEAM_A
  TEAM_B
}

model GameParticipant {
  id            String   @id @default(uuid())
  gameId        String
  participantId String
  team          Team
  points        Int?
  matchBonus    Boolean  @default(false)
  enteredBy     String?
  createdAt     DateTime @default(now())

  // Relations
  game        Game                  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  participant TournamentParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  enterer     User?                 @relation(fields: [enteredBy], references: [id], onDelete: SetNull)

  @@unique([gameId, participantId])
  @@unique([gameId, team, participantId])
  @@index([gameId])
  @@index([participantId])
  @@index([participantId, points])
}

model GameScore {
  id              String   @id @default(uuid())
  gameId          String   @unique
  teamAPoints     Int
  teamBPoints     Int
  teamAMatchBonus Boolean  @default(false)
  teamBMatchBonus Boolean  @default(false)
  enteredBy       String
  enteredAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  game    Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  enterer User @relation(fields: [enteredBy], references: [id])

  @@index([gameId])
}
