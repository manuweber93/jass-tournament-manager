<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="JassTournamentManager.App.Features.Authentication.Components.PreviousParticipationFormView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:resources="clr-namespace:JassTournamentManager.App.Resources.Localization">

    <VerticalStackLayout Spacing="12">
        <Label
            Text="{x:Static resources:AppResources.Register_ClaimUserQuestion}"
            Style="{StaticResource QuestionLabel}" />
    
        <Label
            Text="{x:Static resources:AppResources.Register_ClaimUserQuestionAddOn}"
            Style="{StaticResource MutedLabel}" />

        <Button
            Text="{x:Static resources:AppResources.Register_ClaimUserYesButton}"
            Command="{Binding ShowClaimableUserSelectionCommand}" />

        <Button
            Text="{x:Static resources:AppResources.Register_ClaimUserNoButton}"
            Command="{Binding NoUserClaimingCommand}" 
            Style="{StaticResource SecondaryButton}" />
    </VerticalStackLayout>

</ContentView>