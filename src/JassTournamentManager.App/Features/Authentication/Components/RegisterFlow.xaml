<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="JassTournamentManager.App.Features.Authentication.Components.RegisterFlow"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:resources="clr-namespace:JassTournamentManager.App.Resources.Localization"
    xmlns:components="clr-namespace:JassTournamentManager.App.Features.Authentication.Components">

    <VerticalStackLayout Spacing="12">
        <Label
            Text="{x:Static resources:AppResources.Register_Title}"
            FontSize="22"
            FontAttributes="Bold" />

        <BoxView HeightRequest="1" Opacity="0.2" />

        <components:PreviousParticipationFormView IsVisible="{Binding IsPreviousParticipationQuestionVisible}" />
        <components:UserClaimingFormView IsVisible="{Binding IsClaimableUserSelectionVisible}" />
        <components:RegisterFormView IsVisible="{Binding IsRegistrationFormVisible}" />

    </VerticalStackLayout>

</ContentView>