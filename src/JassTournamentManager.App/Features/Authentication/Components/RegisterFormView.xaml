<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="JassTournamentManager.App.Features.Authentication.Components.RegisterFormView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:resources="clr-namespace:JassTournamentManager.App.Resources.Localization"
    xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material">

    <VerticalStackLayout
    Spacing="12">

        <HorizontalStackLayout Spacing="8">
            <CheckBox IsChecked="{Binding WantsToClaimExistingUser}" />
            <Label
            Text="{x:Static resources:AppResources.Register_ClaimUserCheckboxText}"
            VerticalOptions="Center" />
        </HorizontalStackLayout>

        <VerticalStackLayout
        Spacing="8"
        IsVisible="{Binding WantsToClaimExistingUser}">

            <Label Text="{x:Static resources:AppResources.Register_ChooseUserText}" />

            <Picker
            Title="{x:Static resources:AppResources.Register_ChooseUserPicker}"
            ItemsSource="{Binding ClaimableUsers}"
            SelectedItem="{Binding SelectedClaimableUser}"
            ItemDisplayBinding="{Binding DisplayName}" />
        </VerticalStackLayout>

        <Label
        Text="{x:Static resources:AppResources.Register_Title}"
        FontSize="22"
        FontAttributes="Bold" />

        <material:TextField Title="{x:Static resources:AppResources.Register_FirstName}" Text="{Binding FirstName}" />
        <material:TextField Title="{x:Static resources:AppResources.Register_LastName}" Text="{Binding LastName}" />
        <material:TextField Title="{x:Static resources:AppResources.Register_Email}" Text="{Binding RegisterEmail}" Keyboard="Email" />
        <material:TextField Title="{x:Static resources:AppResources.Register_Password}" Text="{Binding RegisterPassword}" IsPassword="True" />
        <material:TextField Title="{x:Static resources:AppResources.Register_ConfirmPassword}" Text="{Binding ConfirmPassword}" IsPassword="True" />

        <Button Text="{Binding RegisterButtonText}"
            Command="{Binding RegisterCommand}" />
    </VerticalStackLayout>

</ContentView>